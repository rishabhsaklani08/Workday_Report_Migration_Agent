# ──────────────────────────────────────────────────────────────
# Workday Report Catalog Agent — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── Report Catalog Agent (RaaS API) ─────────────────────────
# Workday RaaS report URL (the full URL without ?format=json)
WORKDAY_RAAS_URL=https://[TENANT].workday.com/ccx/service/customreport2/[TENANT]/[USER]/[REPORT_NAME]

# Integration System User credentials
WORKDAY_ISU_USERNAME=[ISU_USERNAME]
WORKDAY_ISU_PASSWORD=[ISU_PASSWORD]

# Timeout & retry settings
WORKDAY_TIMEOUT=60
WORKDAY_RETRIES=3
WORKDAY_RETRY_DELAY=5

# Output directory for generated Excel files
OUTPUT_DIR=./output

# ── Browser Agent (Workday UI Automation) ────────────────────
# Workday tenant URL (the base URL you use to log in)
WORKDAY_TENANT_URL=https://[TENANT].workday.com/[TENANT_NAME]

# Your Workday UI login credentials (NOT the ISU account)
WORKDAY_USERNAME=[YOUR_WORKDAY_USERNAME]
WORKDAY_PASSWORD=[YOUR_WORKDAY_PASSWORD]

# Google Gemini API Key (for LLM-driven browser automation)
GOOGLE_API_KEY=[YOUR_GEMINI_API_KEY]

# Browser settings
BROWSER_HEADLESS=false
BROWSER_TIMEOUT=30000
